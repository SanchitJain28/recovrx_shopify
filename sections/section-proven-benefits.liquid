{{ 'section-proven-benefits.css' | asset_url | stylesheet_tag }}
<script src="{{ 'section-proven-benefits.js' | asset_url }}" defer="defer"></script>

<div class="rx-benefits" style="background-color: {{ section.settings.bg_color }};">
  <div class="page-width">
    <div class="rx-benefits__card">
      <!-- Header Area -->
      <div class="rx-benefits__header">
        <div class="rx-benefits__icon-wrapper">
          <svg
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
          >
            <path d="M9 3v13a3 3 0 0 0 6 0V3"></path>
            <path d="M8 3h8"></path>
            <path d="M9 10h6"></path>
            <path d="M12 21a3 3 0 0 0 3-3"></path>
          </svg>
        </div>
        <h2 class="rx-benefits__title">{{ section.settings.heading }}</h2>
      </div>

      <!-- Columns Area -->
      <div class="rx-benefits__grid">
        {%- for block in section.blocks -%}
          <div class="rx-benefits__item" {{ block.shopify_attributes }}>
            <p class="rx-benefits__text">
              <span class="rx-benefits__text-bold">{{ block.settings.title }}</span>
              {{ block.settings.text }}
            </p>
          </div>
        {%- endfor -%}
      </div>
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Proven Benefits",
  "tag": "section",
  "class": "section",
  "max_blocks": 4,
  "settings": [
    {
      "type": "color",
      "id": "bg_color",
      "label": "Section Background",
      "default": "#FFFFFF"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Scientifically-proven benefits"
    }
  ],
  "blocks": [
    {
      "type": "benefit",
      "name": "Benefit",
      "settings": [
        {
          "type": "text",
          "id": "title",
          "label": "Bold Text",
          "default": "Relieves pain"
        },
        {
          "type": "text",
          "id": "text",
          "label": "Regular Text",
          "default": "and tightness by soothing overworked muscles"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Proven Benefits",
      "blocks": [
        {
          "type": "benefit",
          "settings": {
            "title": "Relieves pain",
            "text": "and tightness by targeting deep tissue knots"
          }
        },
        {
          "type": "benefit",
          "settings": {
            "title": "Increases mobility",
            "text": "and flexibility to support better movement"
          }
        },
        {
          "type": "benefit",
          "settings": {
            "title": "Speeds up recovery",
            "text": "by decreasing muscle soreness and fatigue"
          }
        },
        {
          "type": "benefit",
          "settings": {
            "title": "Enhances performance",
            "text": "by reactivating muscles to boost endurance"
          }
        }
      ]
    }
  ]
}
{% endschema %}
