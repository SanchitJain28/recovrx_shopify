{{ 'section-duo-features.css' | asset_url | stylesheet_tag }}
<script src="{{ 'section-duo-features.js' | asset_url }}" defer="defer"></script>

<section class="rx-duo" aria-labelledby="duo-heading-{{ section.id }}">
  <div class="page-width">
    <!-- Header -->
    <div class="rx-duo__header">
      {%- if section.settings.heading != blank -%}
        <h2 id="duo-heading-{{ section.id }}" class="rx-duo__heading">
          {{ section.settings.heading }}
        </h2>
      {%- endif -%}

      {%- if section.settings.subtext != blank -%}
        <p class="rx-duo__subtext">
          {{ section.settings.subtext }}
        </p>
      {%- endif -%}
    </div>

    <!-- 2-Column Grid -->
    <div class="rx-duo__grid">
      {%- for block in section.blocks -%}
        <div class="rx-duo__card" {{ block.shopify_attributes }}>
          <!-- Top: Image & Overlay Content -->
          <div class="rx-duo__media">
            {%- if block.settings.image != blank -%}
              {{
                block.settings.image
                | image_url: width: 800
                | image_tag: class: 'rx-duo__image', loading: 'lazy', widths: '400, 600, 800', alt: block.settings.title
                | escape
              }}
            {%- else -%}
              {{ 'lifestyle-1' | placeholder_svg_tag: 'rx-duo__image placeholder-svg' }}
            {%- endif -%}

            <div class="rx-duo__overlay"></div>

            <div class="rx-duo__media-content">
              <div class="rx-duo__title-wrap">
                <h3 class="rx-duo__title">{{ block.settings.title }}</h3>
                {%- if block.settings.badge != blank -%}
                  <span class="rx-duo__badge">{{ block.settings.badge }}</span>
                {%- endif -%}
              </div>

              <p class="rx-duo__desc">{{ block.settings.description }}</p>

              {%- if block.settings.btn_text != blank and block.settings.btn_link != blank -%}
                <a href="{{ block.settings.btn_link }}" class="rx-btn rx-duo__btn">
                  {{ block.settings.btn_text }}
                </a>
              {%- endif -%}
            </div>
          </div>

          <!-- Bottom: Footer Claim -->
          <div class="rx-duo__footer">
            <div class="rx-duo__icon-wrap">
              <svg
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
                aria-hidden="true"
              >
                <path d="M9 2h6M12 2v7.5l-5 9.5a2 2 0 0 0 1.7 3h8.6a2 2 0 0 0 1.7-3l-5-9.5V2"/>
              </svg>
            </div>
            <div class="rx-duo__footer-text">
              {{ block.settings.footer_text }}
            </div>
          </div>
        </div>
      {%- endfor -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Duo Lifestyle Features",
  "tag": "section",
  "class": "section-duo-features",
  "max_blocks": 2,
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Experience recovery and relief anytime, anywhere"
    },
    {
      "type": "textarea",
      "id": "subtext",
      "label": "Subtext",
      "default": "From deep muscle treatment to on-the-go relief, our solutions offer the ultimate in athletic self-care and recovery."
    }
  ],
  "blocks": [
    {
      "type": "feature_card",
      "name": "Feature Card",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Background Image"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Product Title",
          "default": "Percussion Massage Gun"
        },
        {
          "type": "text",
          "id": "badge",
          "label": "Small Badge (Optional)",
          "default": "PRO"
        },
        {
          "type": "textarea",
          "id": "description",
          "label": "Description",
          "default": "Clinically proven to reduce muscle soreness, diminish lactic acid and enhance performance."
        },
        {
          "type": "text",
          "id": "btn_text",
          "label": "Button Text",
          "default": "Shop Pro"
        },
        {
          "type": "url",
          "id": "btn_link",
          "label": "Button Link"
        },
        {
          "type": "richtext",
          "id": "footer_text",
          "label": "Footer Claim Text",
          "default": "<p><strong>89% of athletes</strong> stated their muscles felt more rejuvenated after 1 week</p>",
          "info": "Use bold tool to highlight key stats."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Duo Lifestyle Features",
      "blocks": [
        {
          "type": "feature_card",
          "settings": {
            "title": "Percussion Massage Gun",
            "badge": "PRO"
          }
        },
        {
          "type": "feature_card",
          "settings": {
            "title": "Compression Knee Sleeve",
            "badge": "NEW",
            "description": "Our lightest, most breathable compression ever. Relieve aches and ease joint tension wherever life takes you.",
            "btn_text": "Shop Sleeve",
            "footer_text": "<p><strong>Scientifically proven</strong> to ease tension and relieve joint pain</p>"
          }
        }
      ]
    }
  ]
}
{% endschema %}
