{{ 'section-privacy.css' | asset_url | stylesheet_tag }}
<script src="{{ 'section-privacy.js' | asset_url }}" defer></script>

<section class="rx-privacy rx-bg-primary">
  <div class="rx-container rx-privacy__container">
    <div class="rx-privacy__header">
      <h1 class="rx-privacy__title">{{ section.settings.title }}</h1>
      <p class="rx-privacy__subtitle">{{ section.settings.subtitle }}</p>
      <div class="rx-privacy__date">Last Updated: {{ section.settings.last_updated }}</div>
    </div>

    <div class="rx-privacy__content">
      {% for block in section.blocks %}
        <div class="rx-privacy__block" {{ block.shopify_attributes }}>
          <h2 class="rx-privacy__block-title">{{ block.settings.heading }}</h2>
          <div class="rx-privacy__block-text">
            {{ block.settings.content }}
          </div>
        </div>
      {% endfor %}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Privacy Policy",
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": "Page Title",
      "default": "Privacy Policy"
    },
    {
      "type": "textarea",
      "id": "subtitle",
      "label": "Subtitle",
      "default": "Your data security is as important to us as your physical recovery. Here is how we protect your information."
    },
    {
      "type": "text",
      "id": "last_updated",
      "label": "Last Updated Date",
      "default": "October 2023"
    }
  ],
  "blocks": [
    {
      "type": "policy_clause",
      "name": "Privacy Clause",
      "settings": [
        {
          "type": "text",
          "id": "heading",
          "label": "Heading",
          "default": "Clause Heading"
        },
        {
          "type": "richtext",
          "id": "content",
          "label": "Content",
          "default": "<p>Enter your privacy policy details here.</p>"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Privacy Policy Section",
      "blocks": [
        {
          "type": "policy_clause",
          "settings": {
            "heading": "1. Information We Collect",
            "content": "<p>When you visit RecovrX, we automatically collect certain information about your device, including information about your web browser, IP address, time zone, and some of the cookies that are installed on your device. Additionally, as you browse the site, we collect information about the individual products that you view, what websites or search terms referred you to the Site, and information about how you interact with the Site. We refer to this automatically-collected information as <strong>Device Information</strong>.</p><p>When you make a purchase or attempt to make a purchase, we collect certain information from you, including your name, billing address, shipping address, payment information (including credit card numbers), email address, and phone number. We refer to this information as <strong>Order Information</strong>.</p>"
          }
        },
        {
          "type": "policy_clause",
          "settings": {
            "heading": "2. How We Use Your Information",
            "content": "<p>We use the <strong>Order Information</strong> that we collect generally to fulfill any orders placed through the Site (including processing your payment information, arranging for shipping, and providing you with invoices and/or order confirmations). Additionally, we use this Order Information to:</p><ul><li>Communicate with you regarding your recovery gear.</li><li>Screen our orders for potential risk or fraud.</li><li>When in line with the preferences you have shared with us, provide you with clinical tips, updates, or advertising relating to our products.</li></ul><p>We use the <strong>Device Information</strong> that we collect to help us screen for potential risk and fraud (in particular, your IP address), and more generally to improve and optimize our Site.</p>"
          }
        },
        {
          "type": "policy_clause",
          "settings": {
            "heading": "3. Sharing Your Personal Information",
            "content": "<p>We share your Personal Information with third parties to help us use your Personal Information, as described above. For example, we use <strong>Shopify</strong> to power our online store. We also use <strong>Google Analytics</strong> to help us understand how our customers use the Site. Furthermore, data may be shared with our verified logistics partners strictly for the purpose of fulfilling and shipping your order securely.</p><p>Finally, we may also share your Personal Information to comply with applicable laws and regulations, to respond to a subpoena, search warrant or other lawful request for information we receive, or to otherwise protect our rights.</p>"
          }
        },
        {
          "type": "policy_clause",
          "settings": {
            "heading": "4. Data Retention & Security",
            "content": "<p>When you place an order through the Site, we will maintain your Order Information for our records unless and until you ask us to delete this information. Our checkout process is fully encrypted and PCI compliant, ensuring your payment details are never stored on our servers without top-tier clinical-grade encryption.</p>"
          }
        },
        {
          "type": "policy_clause",
          "settings": {
            "heading": "5. Your Rights",
            "content": "<p>If you are a resident of certain jurisdictions, you have the right to access personal information we hold about you and to ask that your personal information be corrected, updated, or deleted. If you would like to exercise this right, please contact our support team through the contact information provided below.</p>"
          }
        },
        {
          "type": "policy_clause",
          "settings": {
            "heading": "6. Contact Us",
            "content": "<p>For more information about our privacy practices, if you have questions, or if you would like to make a complaint, please contact us by e-mail at <strong>support@recovrx.in</strong> or by utilizing our <a href=\"/pages/contact\">Contact Page</a>.</p>"
          }
        }
      ]
    }
  ]
}
{% endschema %}
