{{ 'section-newsletter.css' | asset_url | stylesheet_tag }}
<script src="{{ 'section-newsletter.js' | asset_url }}" defer="defer"></script>

<section class="rx-newsletter" aria-labelledby="newsletter-heading-{{ section.id }}">
  <div class="page-width rx-newsletter__container">
    <div class="rx-newsletter__content">
      {%- if section.settings.heading != blank -%}
        <h2 id="newsletter-heading-{{ section.id }}" class="rx-newsletter__heading">
          {{ section.settings.heading }}
        </h2>
      {%- endif -%}

      {%- if section.settings.subtext != blank -%}
        <p class="rx-newsletter__subtext">
          {{ section.settings.subtext }}
        </p>
      {%- endif -%}
    </div>

    <div class="rx-newsletter__form-wrapper">
      {% form 'customer', class: 'rx-newsletter__form' %}
        <input type="hidden" name="contact[tags]" value="newsletter">

        <div class="rx-newsletter__input-group">
          <label for="NewsletterEmail-{{ section.id }}" class="visually-hidden">Email address</label>
          <input
            id="NewsletterEmail-{{ section.id }}"
            type="email"
            name="contact[email]"
            class="rx-newsletter__input"
            value="{{ form.email }}"
            aria-required="true"
            autocorrect="off"
            autocapitalize="off"
            autocomplete="email"
            {% if form.errors %}
              autofocus
              aria-invalid="true"
              aria-describedby="Newsletter-error-{{ section.id }}"
            {% elsif form.posted_successfully? %}
              aria-describedby="Newsletter-success-{{ section.id }}"
            {% endif %}
            placeholder="{{ section.settings.placeholder }}"
            required
          >
          <button type="submit" class="rx-btn rx-newsletter__btn" name="commit" aria-label="Subscribe">
            {{ section.settings.btn_text }}
          </button>
        </div>

        {%- if form.errors -%}
          <div class="rx-newsletter__message rx-newsletter__message--error" id="Newsletter-error-{{ section.id }}">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
              <circle cx="12" cy="12" r="10"></circle><line x1="12" y1="8" x2="12" y2="12"></line><line x1="12" y1="16" x2="12.01" y2="16"></line>
            </svg>
            {{ form.errors.translated_fields.email | capitalize }}
            {{ form.errors.messages.email }}
          </div>
        {%- endif -%}

        {%- if form.posted_successfully? -%}
          <div
            class="rx-newsletter__message rx-newsletter__message--success"
            id="Newsletter-success-{{ section.id }}"
            tabindex="-1"
            autofocus
          >
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
              <path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"></path><polyline points="22 4 12 14.01 9 11.01"></polyline>
            </svg>
            Thanks for subscribing! Check your email for your discount code.
          </div>
        {%- endif -%}
      {% endform %}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Newsletter",
  "tag": "section",
  "class": "section-newsletter",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Unlock 10% Off Your First Order"
    },
    {
      "type": "textarea",
      "id": "subtext",
      "label": "Subtext",
      "default": "Join the RecovrX community. Get exclusive access to product drops, recovery protocols, and VIP offers."
    },
    {
      "type": "text",
      "id": "placeholder",
      "label": "Input Placeholder",
      "default": "Enter your email address"
    },
    {
      "type": "text",
      "id": "btn_text",
      "label": "Button Text",
      "default": "Subscribe"
    }
  ],
  "presets": [
    {
      "name": "Newsletter Form",
      "category": "Promotional"
    }
  ]
}
{% endschema %}
