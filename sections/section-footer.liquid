{{ 'section-footer.css' | asset_url | stylesheet_tag }}

<footer class="rx-footer" aria-labelledby="footer-heading">
  <h2 id="footer-heading" class="visually-hidden">Footer</h2>

  <div class="page-width">
    <!-- Top Main Area: Columns with Vertical Borders -->
    <div class="rx-footer__main">
      {%- liquid
        assign col_limit = section.settings.max_collections | default: 3
        assign col_count = 0
      -%}

      <!-- Dynamic Collection Columns -->
      {%- for collection in collections -%}
        {%- if collection.handle != 'frontpage' and collection.handle != 'all' and collection.products_count > 0 -%}
          {%- if col_count < col_limit -%}
            <div class="rx-footer__col">
              <h4 class="rx-footer__heading">{{ collection.title | escape }}</h4>
              <ul class="rx-footer__list" role="list">
                {%- for product in collection.products limit: 5 -%}
                  <li>
                    <a href="{{ product.url }}" class="rx-footer__link">{{ product.title | escape }}</a>
                  </li>
                {%- endfor -%}
                {%- if collection.products_count > 5 -%}
                  <li>
                    <a href="{{ collection.url }}" class="rx-footer__link rx-footer__link--all"
                      >Shop All {{ collection.title }} &rarr;</a
                    >
                  </li>
                {%- endif -%}
              </ul>
            </div>
            {%- assign col_count = col_count | plus: 1 -%}
          {%- endif -%}
        {%- endif -%}
      {%- endfor -%}

      <!-- Static Column 1: Support -->
      <div class="rx-footer__col">
        <h4 class="rx-footer__heading">Support</h4>
        <ul class="rx-footer__list" role="list">
          <li><a href="/pages/faq" class="rx-footer__link">FAQ</a></li>
          <li><a href="/pages/contact" class="rx-footer__link">Contact Us</a></li>
          <li><a href="/pages/shipping-returns" class="rx-footer__link">Return Policy</a></li>
          <li><a href="/pages/shipping-returns" class="rx-footer__link">Shipping Policy</a></li>
          <li><a href="/pages/shipping-returns" class="rx-footer__link">Warranty Terms</a></li>
        </ul>
      </div>

      <!-- Static Column 2: Company -->
      <div class="rx-footer__col">
        <h4 class="rx-footer__heading">Company</h4>
        <ul class="rx-footer__list" role="list">
          <li><a href="/pages/about-us" class="rx-footer__link">Our Science</a></li>
          <li><a href="/pages/about-us" class="rx-footer__link">Blog</a></li>
          <li><a href="/pages/about-us" class="rx-footer__link">Careers</a></li>
          <li><a href="/pages/about-us" class="rx-footer__link">Affiliates</a></li>
        </ul>
      </div>
    </div>

    <!-- Bottom Area: Socials, Legal, Copyright -->
    <div class="rx-footer__bottom">
      <!-- Left: Social Icons -->
      <div class="rx-footer__socials">
        {%- if section.settings.social_instagram != blank -%}
          <a
            href="{{ section.settings.social_instagram }}"
            class="rx-footer__social-link"
            aria-label="Instagram"
            target="_blank"
            rel="noopener"
          >
            <svg
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
            >
              <rect x="2" y="2" width="20" height="20" rx="5" ry="5"></rect><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"></path><line x1="17.5" y1="6.5" x2="17.51" y2="6.5"></line>
            </svg>
          </a>
        {%- endif -%}
        {%- if section.settings.social_facebook != blank -%}
          <a
            href="{{ section.settings.social_facebook }}"
            class="rx-footer__social-link"
            aria-label="Facebook"
            target="_blank"
            rel="noopener"
          >
            <svg
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
            >
              <path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"></path>
            </svg>
          </a>
        {%- endif -%}
        {%- if section.settings.social_twitter != blank -%}
          <a
            href="{{ section.settings.social_twitter }}"
            class="rx-footer__social-link"
            aria-label="X (Twitter)"
            target="_blank"
            rel="noopener"
          >
            <!-- X Logo SVG -->
            <svg viewBox="0 0 24 24" fill="currentColor">
              <path d="M18.901 1.153h3.68l-8.04 9.19L24 22.846h-7.406l-5.8-7.584-6.638 7.584H.474l8.6-9.83L0 1.154h7.594l5.243 6.932ZM17.61 20.644h2.039L6.486 3.24H4.298Z"/>
            </svg>
          </a>
        {%- endif -%}
        {%- if section.settings.social_youtube != blank -%}
          <a
            href="{{ section.settings.social_youtube }}"
            class="rx-footer__social-link"
            aria-label="YouTube"
            target="_blank"
            rel="noopener"
          >
            <svg
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
            >
              <path d="M22.54 6.42a2.78 2.78 0 0 0-1.94-2C18.88 4 12 4 12 4s-6.88 0-8.6.46a2.78 2.78 0 0 0-1.94 2A29 29 0 0 0 1 11.75a29 29 0 0 0 .46 5.33A2.78 2.78 0 0 0 3.4 19c1.72.46 8.6.46 8.6.46s6.88 0 8.6-.46a2.78 2.78 0 0 0 1.94-2 29 29 0 0 0 .46-5.25 29 29 0 0 0-.46-5.33z"></path><polygon points="9.75 15.02 15.5 11.75 9.75 8.48 9.75 15.02"></polygon>
            </svg>
          </a>
        {%- endif -%}
      </div>

      <!-- Center: Legal Links -->
      <div class="rx-footer__legal">
        <a href="/pages/privacy-policy" class="rx-footer__legal-link">Privacy Policy</a>
        <a href="/pages/privacy-policy" class="rx-footer__legal-link">Terms of Service</a>
        <a href="/pages/privacy-policy" class="rx-footer__legal-link">Accessibility</a>
      </div>

      <!-- Right: Copyright -->
      <div class="rx-footer__copyright">
        &copy; {{ 'now' | date: '%Y' }}
        {{ shop.name }}, Inc. All rights reserved.
      </div>
    </div>
  </div>
</footer>

{% schema %}
{
  "name": "Custom Footer",
  "tag": "section",
  "class": "section-footer",
  "settings": [
    {
      "type": "range",
      "id": "max_collections",
      "min": 1,
      "max": 4,
      "step": 1,
      "label": "Max Collection Columns",
      "info": "Automatically fetches your active collections and lists their products.",
      "default": 3
    },
    {
      "type": "header",
      "content": "Social Media Links"
    },
    {
      "type": "url",
      "id": "social_instagram",
      "label": "Instagram Link"
    },
    {
      "type": "url",
      "id": "social_facebook",
      "label": "Facebook Link"
    },
    {
      "type": "url",
      "id": "social_twitter",
      "label": "X (Twitter) Link"
    },
    {
      "type": "url",
      "id": "social_youtube",
      "label": "YouTube Link"
    }
  ]
}
{% endschema %}
