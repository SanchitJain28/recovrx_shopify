{%- comment -%}
  RecovrX Product Media Gallery
  Usage: {% render 'product-media-gallery' %}
{%- endcomment -%}

{{ 'section-product-media-gallery.css' | asset_url | stylesheet_tag }}
<script src="{{ 'section-product-media-gallery.js' | asset_url }}" defer="defer"></script>

<div id="RxMediaGallery-{{ section.id }}" class="rx-media-gallery">
  <!-- Thumbnails (Left Column) -->
  <div class="rx-media-gallery__thumbnails">
    <ul class="rx-thumbnail-list" role="list">
      {%- for media in product.media -%}
        <li class="rx-thumbnail-list__item">
          <button
            class="rx-thumbnail-btn {% if forloop.first %}is-active{% endif %}"
            data-target="RxSlide-{{ section.id }}-{{ media.id }}"
            aria-label="{{ 'products.product.media.load_image' | t: index: forloop.index | default: 'Load image' }}"
          >
            {{ media.preview_image | image_url: width: 150 | image_tag: loading: 'lazy', class: 'rx-thumbnail-img' }}
          </button>
        </li>
      {%- endfor -%}
    </ul>
  </div>

  <!-- Main Viewer (Right Column) -->
  <div class="rx-media-gallery__main">
    <ul class="rx-main-list" role="list">
      {%- for media in product.media -%}
        <li
          id="RxSlide-{{ section.id }}-{{ media.id }}"
          class="rx-main-list__item {% if forloop.first %}is-active{% endif %}"
          data-media-id="{{ media.id }}"
        >
          {%- if media.media_type == 'image' -%}
            {{
              media.preview_image
              | image_url: width: 1200
              | image_tag: loading: 'lazy', class: 'rx-main-img', alt: media.alt
              | escape
            }}
          {%- else -%}
            <div class="rx-main-media-container">
              {{
                media
                | media_tag: image_size: '1024x', autoplay: true, loop: true, controls: true, class: 'rx-main-media-tag'
              }}
            </div>
          {%- endif -%}
        </li>
      {%- endfor -%}
    </ul>
  </div>
</div>
