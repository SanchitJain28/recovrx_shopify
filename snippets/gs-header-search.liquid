<form action="{{ routes.search_url }}" method="get" class="gs-search-form" role="search">
  <input type="hidden" name="type" value="product">
  <input type="hidden" name="options[prefix]" value="last">

  <div class="gs-search-input-wrapper">
    <input
      type="text"
      name="q"
      value="{{ search.terms | escape }}"
      placeholder="Search for gifts"
      class="gs-search-input js-predictive-input"
      autocomplete="off"
      required
    >
    <button type="submit" class="gs-search-submit" aria-label="Search">
      <i class="fa-solid fa-magnifying-glass"></i>
    </button>
  </div>

  <div class="gs-predictive-results js-predictive-results">
    <div class="gs-predictive__loading js-predictive-loading" hidden>
      <div class="gs-predictive__skeleton">
        <div class="gs-skeleton-item"></div>
        <div class="gs-skeleton-item"></div>
        <div class="gs-skeleton-item"></div>
      </div>
    </div>
  </div>
</form>
