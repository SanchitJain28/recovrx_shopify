{% comment %}
  Renders a RecovrX product card.
  Accepts:
  - card_product: {Object} Product Liquid object
{% endcomment %}

{%- if card_product and card_product != empty -%}
  {%- liquid
    assign target = card_product.selected_or_first_available_variant
    assign compare_at_price = target.compare_at_price
    assign price = target.price
    assign available = target.available
    assign description_text = card_product.description | strip_html | truncate: 80
  -%}

  {{ 'component-card-custom.css' | asset_url | stylesheet_tag }}

  <div class="rx-card-wrapper product-card">
    <a href="{{ card_product.url }}" class="rx-card" aria-label="{{ card_product.title | escape }}">
      <div class="rx-card__image-wrap">
        {%- if card_product.featured_media -%}
          <img
            src="{{ card_product.featured_media | image_url: width: 800 }}"
            alt="{{ card_product.featured_media.alt | escape }}"
            class="rx-card__image"
            loading="lazy"
            width="{{ card_product.featured_media.width }}"
            height="{{ card_product.featured_media.height }}"
          >
          {%- if card_product.media[1] != null -%}
            <img
              src="{{ card_product.media[1] | image_url: width: 800 }}"
              alt="{{ card_product.media[1].alt | escape }}"
              class="rx-card__image rx-card__image--hover"
              loading="lazy"
              width="{{ card_product.media[1].width }}"
              height="{{ card_product.media[1].height }}"
            >
          {%- endif -%}
        {%- else -%}
          {{ 'product-1' | placeholder_svg_tag: 'rx-card__image rx-card__image--placeholder' }}
        {%- endif -%}

        {%- unless available -%}
          <span class="rx-card__badge rx-card__badge--soldout">Sold Out</span>
        {%- else -%}
          {%- if compare_at_price > price -%}
            {%- assign savings = compare_at_price | minus: price | times: 100 | divided_by: compare_at_price -%}
            <span class="rx-card__badge rx-card__badge--sale">{{ savings }}% OFF</span>
          {%- endif -%}
        {%- endunless -%}
      </div>

      <div class="rx-card__body">
        <p class="rx-card__title">{{ card_product.title | escape }}</p>

        {%- if description_text != blank -%}
          <p class="rx-card__desc">{{ description_text }}</p>
        {%- endif -%}

        <div class="rx-card__footer">
          <div class="rx-card__prices">
            <span class="rx-card__price">{{ price | money }}</span>
            {%- if compare_at_price > price -%}
              <span class="rx-card__compare">{{ compare_at_price | money }}</span>
            {%- endif -%}
          </div>
          <button
            type="button"
            class="rx-card__atc"
            data-variant-id="{{ target.id }}"
            aria-label="Add {{ card_product.title | escape }} to cart"
            {% unless available %}
              disabled
            {% endunless %}
          >
            <svg
              width="14"
              height="14"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2.5"
              stroke-linecap="round"
              stroke-linejoin="round"
              aria-hidden="true"
            >
              <line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/>
            </svg>
          </button>
        </div>
      </div>
    </a>
  </div>

{%- else -%}
  {{ 'component-card-custom.css' | asset_url | stylesheet_tag }}

  <div class="rx-card-wrapper product-card">
    <a href="#" class="rx-card" aria-label="Placeholder product">
      <div class="rx-card__image-wrap">
        {{ 'product-1' | placeholder_svg_tag: 'rx-card__image rx-card__image--placeholder' }}
      </div>
      <div class="rx-card__body">
        <p class="rx-card__title">Percussion Massage Gun</p>
        <p class="rx-card__desc">Professional-grade deep tissue percussive therapy for faster muscle recovery.</p>
        <div class="rx-card__footer">
          <div class="rx-card__prices">
            <span class="rx-card__price">₹3,999</span>
            <span class="rx-card__compare">₹6,999</span>
          </div>
          <button type="button" class="rx-card__atc" aria-label="Add to cart">
            <svg
              width="14"
              height="14"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2.5"
              stroke-linecap="round"
              stroke-linejoin="round"
              aria-hidden="true"
            >
              <line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/>
            </svg>
          </button>
        </div>
      </div>
    </a>
  </div>
{%- endif -%}

<script src="{{ 'component-card-custom.js' | asset_url }}" defer></script>
